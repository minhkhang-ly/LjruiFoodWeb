@model IReadOnlyList<ReviewViewModel>
@{
    ViewData["Title"] = "Review";
}

<div class="review-page">
    <h1 class="section-title">ĐÁNH GIÁ <span class="gold">NỔI BẬT</span></h1>
    <div class="review-grid">
        @foreach (var r in Model)
        {
            <article class="review-card">
                <div class="review-card__head">
                    <div class="review-avatar" aria-hidden="true">@r.AvatarInitial</div>
                    <div class="review-user">
                        <strong>@r.UserName</strong>
                    </div>
                    <div class="product-chip">
                        <i class="fa-solid fa-burger"></i>
                        <span>@r.ProductName</span>
                    </div>
                </div>
                <p class="review-body">@r.Comment</p>
                <div class="review-footer">
                    <div class="stars" aria-label="@r.StarRating trên 5 sao">
                        @for (var i = 1; i <= 5; i++)
                        {
                            if (i <= r.StarRating)
                            {
                                <i class="fa-solid fa-star"></i>
                            }
                            else
                            {
                                <i class="fa-regular fa-star"></i>
                            }
                        }
                    </div>
                    <span class="review-date">@r.ReviewDate</span>
                </div>
            </article>
        }
    </div>
</div>

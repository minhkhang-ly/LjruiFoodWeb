@model IReadOnlyList<ProductViewModel>
@{
    ViewData["Title"] = "Menu";
}

<div class="menu-page">
    <div class="menu-toolbar">
        <div class="filter-pills" role="tablist" aria-label="Bộ lọc">
            <span class="filter-pill filter-pill--active" role="tab" aria-selected="true">Tất Cả</span>
            <span class="filter-pill" role="tab" aria-selected="false">Đồ Ăn</span>
            <span class="filter-pill" role="tab" aria-selected="false">Đồ Uống</span>
        </div>
        <div class="sort-select">
            <label class="visually-hidden" for="sortDefault">Sắp xếp</label>
            <select id="sortDefault" name="sortDefault">
                <option>Sắp Xếp Mặc Định</option>
            </select>
        </div>
    </div>

    <div class="menu-layout">
        <div class="product-grid">
            @foreach (var p in Model)
            {
                <article class="product-card">
                    <div class="product-card__media">
                        <span class="product-card__badge">@p.SoldCount Đã Bán</span>
                        <img src="@p.ImageUrl" alt="@p.Name" />
                    </div>
                    <div class="product-card__body">
                        <p class="product-card__cat">@p.CategoryLabel</p>
                        <h2 class="product-card__title">@p.Name</h2>
                        <div class="stars" aria-label="Đánh giá @p.StarRating trên 5">
                            @for (var i = 1; i <= 5; i++)
                            {
                                if (i <= p.StarRating)
                                {
                                    <i class="fa-solid fa-star"></i>
                                }
                                else
                                {
                                    <i class="fa-regular fa-star"></i>
                                }
                            }
                            <span class="muted">(@p.ReviewCount)</span>
                        </div>
                        <div class="price-row">
                            @if (p.OriginalPrice is { } old)
                            {
                                <span class="price-old">@old.ToVnd()</span>
                            }
                            @if (p.DiscountPercent is { } d)
                            {
                                <span class="discount-badge">@d%</span>
                            }
                            <span class="price-current">@p.CurrentPrice.ToVnd()</span>
                        </div>
                        <p class="product-card__desc">@p.Description</p>
                    </div>
                </article>
            }
        </div>

        <aside class="search-panel" aria-label="Tìm kiếm (giao diện tĩnh)">
            <div class="search-panel__field">
                <input type="search" value="Gà rán" readonly />
                <button type="button" class="clear" aria-label="Xóa"><i class="fa-solid fa-xmark"></i></button>
                <button type="button" aria-label="Tìm"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
            <div class="search-section">
                <h3>GỢI Ý TÌM KIẾM</h3>
                <ul class="search-list">
                    <li>Gà Rán Giòn <span class="type">Đồ Ăn</span></li>
                    <li>Gà Rán KFC <span class="type">Combo</span></li>
                    <li>Combo Gà Rán + Khoai Tây <span class="type">Combo</span></li>
                    <li>Combo Burger + Gà Rán <span class="type">Combo</span></li>
                </ul>
            </div>
            <div class="search-section">
                <h3>MÓN ĂN PHỔ BIẾN</h3>
                <ul class="search-list">
                    <li>Hamburger Bò <span class="type">Đồ Ăn</span></li>
                    <li>Bún Bò Huế <span class="type">Đồ Ăn</span></li>
                    <li>Gà Rán KFC <span class="type">Combo</span></li>
                </ul>
            </div>
        </aside>
    </div>
</div>

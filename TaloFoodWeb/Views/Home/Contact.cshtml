@{
    ViewData["Title"] = "Liên hệ";
}

<div class="contact-page">
    <header class="page-hero">
        <h1>Liên Hệ Với Chúng Tôi</h1>
        <p>Chúng Tôi Luôn Lắng Nghe Và Sẵn Sàng Hỗ Trợ Bạn. Hãy Chia Sẻ Với Chúng Tôi Những Điều Bạn Quan Tâm.</p>
    </header>

    <div class="contact-grid">
        <section class="contact-card" aria-labelledby="contact-info-title">
            <h2 id="contact-info-title">Thông Tin Liên Hệ</h2>
            <hr />
            <div class="contact-block">
                <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                <div>
                    <h3>Địa Chỉ</h3>
                    <p>347/12A Chu Văn An, Phường Bình Thạnh, Thành Phố Hồ Chí Minh, Việt Nam</p>
                </div>
            </div>
            <div class="contact-block">
                <i class="fa-solid fa-phone" aria-hidden="true"></i>
                <div>
                    <h3>Điện Thoại</h3>
                    <p>+84 123 456 789</p>
                    <p>+84 987 654 321</p>
                </div>
            </div>
            <div class="contact-block">
                <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                <div>
                    <h3>Email</h3>
                    <p>Info@Talofood.Com</p>
                    <p>Support@Talofood.Com</p>
                </div>
            </div>
            <div class="contact-block">
                <i class="fa-solid fa-clock" aria-hidden="true"></i>
                <div>
                    <h3>Giờ Mở Cửa</h3>
                    <p>Thứ 2 - Thứ 6: 9:00 - 22:00</p>
                    <p>Thứ 7 - Chủ Nhật: 10:00 - 23:00</p>
                </div>
            </div>
            <div class="social-row" aria-label="Mạng xã hội">
                <a class="social-btn" href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                <a class="social-btn" href="#" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
                <a class="social-btn" href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                <a class="social-btn" href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
            </div>
        </section>

        <section class="contact-card" aria-labelledby="contact-form-title">
            <h2 id="contact-form-title">Gửi Tin Nhắn</h2>
            <hr />
            <form class="form-stack" method="get" action="#">
                <label for="message">Nội Dung Tin Nhắn</label>
                <textarea id="message" name="message" placeholder="Hãy Chia Sẻ Với Chúng Tôi Câu Hỏi Hoặc Phản Hồi Của Bạn..."></textarea>
                <div style="margin-top:16px">
                    <button type="button" class="btn-gold"><i class="fa-solid fa-paper-plane"></i> Gửi Tin Nhắn</button>
                </div>
            </form>
        </section>
    </div>
</div>

@model LjruiFoodWeb.Models.DanhMuc

@{
    ViewData["Title"] = "Thêm danh mục mới";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0">Thêm danh mục mới</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Ten" class="form-label">Tên danh mục</label>
                            <input asp-for="Ten" class="form-control" placeholder="Nhập tên danh mục..." />
                            <span asp-validation-for="Ten" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Slug" class="form-label">Đường dẫn tĩnh (Slug)</label>
                            <input asp-for="Slug" class="form-control" placeholder="vi-du-danh-muc" />
                            <span asp-validation-for="Slug" class="text-danger"></span>
                            <small class="form-text text-muted">Nếu để trống, hệ thống sẽ tự động tạo từ tên danh mục.</small>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="MoTa" class="form-label">Mô tả</label>
                            <textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Mô tả về danh mục..."></textarea>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Lưu danh mục
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

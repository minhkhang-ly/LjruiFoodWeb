@model LjruiFoodWeb.Models.DanhMuc

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="card-title mb-0">Xác nhận xóa danh mục</h3>
                </div>
                <div class="card-body">
                    <h5 class="text-danger mb-4">Bạn có chắc chắn muốn xóa danh mục này? Hệ thống có thể gặp lỗi nếu danh mục này đang chứa sản phẩm.</h5>
                    
                    <dl class="row mb-4">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.Ma</dd>

                        <dt class="col-sm-4">Tên danh mục</dt>
                        <dd class="col-sm-8 fw-bold">@Model.Ten</dd>

                        <dt class="col-sm-4">Slug</dt>
                        <dd class="col-sm-8">@Model.Slug</dd>

                        <dt class="col-sm-4">Mô tả</dt>
                        <dd class="col-sm-8">@Model.MoTa</dd>
                    </dl>
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Ma" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Hủy và quay lại
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Xác nhận xóa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

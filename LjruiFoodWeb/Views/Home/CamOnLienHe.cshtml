@model string
@{
    ViewData["Title"] = "Đã gửi tin nhắn";
}

<div class="inner-page" style="text-align:center;max-width:640px">
    <div style="font-size:3rem;color:var(--accent);margin-bottom:12px"><i class="fa-solid fa-paper-plane"></i></div>
    <h1>Chúng Tôi Đã Nhận Tin Nhắn</h1>
    <p style="color:var(--text-muted);margin-bottom:16px">Cảm ơn bạn đã liên hệ LjruiFood. Đội ngũ sẽ phản hồi sớm nhất có thể.</p>
    <div class="contact-card" style="text-align:left;margin:20px auto;padding:18px">
        <h2 style="margin-top:0;color:var(--accent-soft);font-size:1rem">Nội dung bạn gửi (trích)</h2>
        <p style="margin:0;white-space:pre-wrap;color:#eee">@Model</p>
    </div>
    <a class="btn-gold" asp-action="Contact">Gửi Tin Khác</a>
    <a class="btn-outline" asp-action="Index" style="margin-left:12px">Về Trang Chủ</a>
</div>

@model LienHeFormModel
@{
    ViewData["Title"] = "Liên hệ";
}

<div class="contact-page">
    <header class="page-hero">
        <h1>Liên Hệ Với Chúng Tôi</h1>
        <p>Chúng tôi luôn lắng nghe và sẵn sàng hỗ trợ bạn. Hãy chia sẻ với chúng tôi những điều bạn quan tâm.</p>
    </header>

    <div class="contact-grid">
        <section class="contact-card" aria-labelledby="contact-info-title">
            <h2 id="contact-info-title">Thông Tin Liên Hệ</h2>
            <hr />
            <div class="contact-block">
                <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                <div>
                    <h3>Địa Chỉ</h3>
                    <p>347/12A Chu Văn An, Phường Bình Thạnh, Thành Phố Hồ Chí Minh, Việt Nam</p>
                </div>
            </div>
            <div class="contact-block">
                <i class="fa-solid fa-phone" aria-hidden="true"></i>
                <div>
                    <h3>Điện Thoại</h3>
                    <p>+84 123 456 789</p>
                    <p>+84 987 654 321</p>
                </div>
            </div>
            <div class="contact-block">
                <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                <div>
                    <h3>Email</h3>
                    <p>Info@LjruiFood.Com</p>
                    <p>Support@LjruiFood.Com</p>
                </div>
            </div>
            <div class="contact-block">
                <i class="fa-solid fa-clock" aria-hidden="true"></i>
                <div>
                    <h3>Giờ Mở Cửa</h3>
                    <p>Thứ 2 - Thứ 6: 9:00 - 22:00</p>
                    <p>Thứ 7 - Chủ Nhật: 10:00 - 23:00</p>
                </div>
            </div>
            <div class="social-row" aria-label="Mạng xã hội">
                <a class="social-btn" asp-action="MangXaHoi" asp-route-kenh="facebook" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                <a class="social-btn" asp-action="MangXaHoi" asp-route-kenh="twitter" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
                <a class="social-btn" asp-action="MangXaHoi" asp-route-kenh="instagram" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                <a class="social-btn" asp-action="MangXaHoi" asp-route-kenh="youtube" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
            </div>
        </section>

        <section class="contact-card" aria-labelledby="contact-form-title">
            <h2 id="contact-form-title">Gửi Tin Nhắn</h2>
            <hr />
            <form class="form-stack" asp-action="GuiLienHe" method="post">
                <div asp-validation-summary="ModelOnly" class="field-error" style="margin-bottom:12px"></div>
                <label asp-for="NoiDung">Nội Dung Tin Nhắn</label>
                <textarea asp-for="NoiDung" placeholder="Hãy Chia Sẻ Với Chúng Tôi Câu Hỏi Hoặc Phản Hồi Của Bạn..."></textarea>
                <span asp-validation-for="NoiDung" class="field-error"></span>
                <div style="margin-top:16px">
                    <button type="submit" class="btn-gold"><i class="fa-solid fa-paper-plane"></i> Gửi Tin Nhắn</button>
                </div>
            </form>
        </section>
    </div>
</div>

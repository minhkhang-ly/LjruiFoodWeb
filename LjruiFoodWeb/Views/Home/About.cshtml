@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="simple-page">
    <h1>Về LjruiFood</h1>
    <p class="lead" style="color:var(--accent-subtitle);font-weight:600">
        LjruiFood là thương hiệu đồ ăn nhanh và đồ uống phục vụ tại TP.HCM, hướng tới hương vị quen thuộc, tốc độ giao nhanh và trải nghiệm đặt món đơn giản.
    </p>
    <section class="contact-card" style="margin-top:24px;text-align:left">
        <h2 style="margin-top:0;color:var(--accent-soft)">Sứ mệnh</h2>
        <p>Mang đến bữa ăn đủ dinh dưỡng, ấm nóng và hợp khẩu vị Việt — từ bún, pizza, burger đến cà phê sữa đá hay trà trái cây.</p>
        <h2 style="color:var(--accent-soft)">Cam kết</h2>
        <ul style="color:var(--text-muted);line-height:1.7">
            <li>Nguyên liệu tuyển chọn, quy trình chế biến minh bạch.</li>
            <li>Đóng gói cẩn thận, nhãn thời gian rõ ràng.</li>
            <li>Đội ngũ hỗ trợ luôn sẵn sàng qua trang liên hệ.</li>
        </ul>
        <div class="btn-row" style="margin-top:20px">
            <a class="btn-gold" asp-action="Menu">Xem Thực Đơn</a>
            <a class="btn-outline" asp-action="Contact">Liên Hệ Hợp Tác</a>
        </div>
    </section>
</div>
